---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import BoardMembersTable from '../components/BoardMembersTable.astro';
import { boardMembers } from '../data/boardMembers';
---

<Layout title="關於我們 | 臺灣高效能運算教育協會">
  <Header />
  
  <main>
    <PageHero 
      title="關於我們"
      subtitle="以高效能運算為核心，推動教育創新，培育引領未來的關鍵人才。"
    />

    <Section background="white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-8 text-center">臺灣高效能運算教育協會</h2>
        <div class="text-center mb-12">
          <p class="text-xl text-brand-secondary leading-relaxed">
            致力於推進臺灣高效能運算和 IC 設計教育
          </p>
        </div>
        
        <div>
          <h3 class="text-2xl font-semibold text-brand-primary mb-6 text-center">我們的願景與目標</h3>
          <div class="bg-brand-light p-8 rounded-xl">
            <p style="text-indent: 2em; margin-bottom: 1em;">
              臺灣高效能運算教育協會 (TWHPCEdu, Taiwan High Performance Computing Education Association) 
  致力於培養下一代具備創新與實作能力的人才，推動臺灣在高效能運算與 IC 設計領域持續前進。
            </p>

            <p style="text-indent: 2em; margin-bottom: 1em;">
              我們相信，科技教育不只是課本上的理論，而是要透過實際操作、跨域合作，讓更多人有機會親手參與、解決真實問題。協會結合學界研究能量與業界實務經驗，打造一個公開透明、開源共享的學習與研究平台，讓學員能在實作中成長，也讓專家能自由傳承知識。
            </p>

            <p style="text-indent: 2em;">
              我們的願景，是讓更多人具備在未來關鍵技術領域中發光的能力，成為推動臺灣科技發展的核心力量，並在快速演進的時代裡，建立一個持續學習、持續成長的文化。
            </p>
          </div>
        </div>
      </div>
    </Section>

    <!-- Board Members Section -->
    <Section id="board" background="light" class="-mt-16">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-primary mb-8 text-center">理監事成員</h2>
        <p class="text-center text-brand-secondary mb-12">認識指導我們協會的理監事成員</p>
        <BoardMembersTable members={boardMembers} />
      </div>
    </Section>

    <!-- History Section (hidden) -->
    <Section id="history" background="white" class="hidden">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-primary mb-8 text-center">我們的歷程</h2>
        <p class="text-center text-brand-secondary mb-12">臺灣高效能運算教育協會的故事</p>
        
        <div class="space-y-8">
          <div class="bg-brand-light p-6 rounded-xl">
            <h3 class="text-xl font-semibold text-brand-primary mb-4">協會成立</h3>
            <p class="text-brand-secondary leading-relaxed">
              臺灣高效能運算教育協會正式成立，匯集學界與產業專家，共同推動高效能運算教育。
            </p>
          </div>
          
          <div class="bg-brand-surface border border-brand-border p-6 rounded-xl">
            <h3 class="text-xl font-semibold text-brand-primary mb-4">理監事會議與會員大會</h3>
            <div class="space-y-4">
              <div class="flex items-start">
                <div class="flex-shrink-0 w-4 h-4 bg-brand-accent rounded-full mt-2 mr-4"></div>
                <div>
                  <h4 class="font-semibold text-brand-primary mb-1">三月理監事會議</h4>
                  <p class="text-brand-secondary">規劃今年年度執行目標</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="flex-shrink-0 w-4 h-4 bg-brand-accent rounded-full mt-2 mr-4"></div>
                <div>
                  <h4 class="font-semibold text-brand-primary mb-1">六月會員大會</h4>
                  <p class="text-brand-secondary">向會員報告今年年度計畫，預計擴大協會教育計畫，及尋找企業夥伴</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>

    <!-- Annual Report Section -->
    <section id="annual-report" class="py-16 bg-gray-50 hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-8">年度報告</h2>
          <p class="text-lg text-gray-600 mb-8">
            查看我們的年度成果報告，了解協會在推動高效能運算教育方面的具體成就
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a href="#" class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">2023年度報告</h3>
              <p class="text-gray-600 mb-4">回顧2023年的重要成就與發展里程碑</p>
              <span class="text-primary-600 font-medium">下載 PDF →</span>
            </a>
            <a href="#" class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">2022年度報告</h3>
              <p class="text-gray-600 mb-4">了解2022年的教育推廣與研究成果</p>
              <span class="text-primary-600 font-medium">下載 PDF →</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Partners Section -->
    <section id="partners" class="py-16 hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">合作夥伴</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">台灣大學</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">清華大學</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">交通大學</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">中央研究院</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">成功大學</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">中山大學</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">NVIDIA</span>
            </div>
            <div class="bg-gray-100 h-24 rounded-lg flex items-center justify-center">
              <span class="text-gray-500 font-medium">Intel</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
