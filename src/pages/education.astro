---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="教育培訓 | 臺灣高效能運算教育協會">
  <Header />
  
  <main>
    <PageHero 
      title="教育培訓"
      subtitle="提供系統性的高效能運算課程，從基礎概念到進階應用，培養專業技能"
    />

    <!-- Course Features -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold text-brand-primary mb-6">課程特色</h2>
          <p class="text-lg text-brand-secondary">
            我們的教育培訓課程結合理論與實務，提供完整的學習體驗
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13M12 6.253C10.832 5.477 9.61 5 8.25 5H6.75A2.25 2.25 0 004.5 7.25v12c1.5-1 3-1.5 4.5-1.5s3 .5 4.5 1.5m0-12.997C13.168 5.477 14.39 5 15.75 5h1.5A2.25 2.25 0 0119.5 7.25v12c-1.5-1-3-1.5-4.5-1.5s-3 .5-4.5 1.5"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">理論與實務並重</h3>
            <p class="text-brand-secondary">結合理論講解與 PBL 實作，確保學習成效</p>
          </div>

          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <i class="fa-solid fa-chalkboard-user text-primary-600 text-3xl" aria-hidden="true"></i>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">產學師資共同指導</h3>
            <p class="text-brand-secondary">專家教授聯手帶領，最新技術與實務一次到手</p>
          </div>

          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <!-- Inline certification badge icon to avoid CDN dependency -->
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="10" r="4" stroke-width="2" />
                <path d="M8.5 13.5L7 20l5-2 5 2-1.5-6.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M10 10.5l1.5 1.5L14.5 9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">專業認證加值履歷</h3>
            <p class="text-brand-secondary">完成課程可取得業界認可的證書，履歷更亮眼</p>
          </div>

          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">線上學習平台</h3>
            <p class="text-brand-secondary">24/7 線上平台，讓你兼顧工作、課業與進修</p>
          </div>

          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <i class="fa-solid fa-gear text-primary-600 text-3xl" aria-hidden="true"></i>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">高效能運算設備實作</h3>
            <p class="text-brand-secondary">提供真實 HPC 環境，提前接軌產業</p>
          </div>

          <div class="bg-white rounded-xl shadow-lg p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-primary mb-4">學習社群與專案交流</h3>
            <p class="text-brand-secondary">加入多元背景的社群，拓展人脈與視野</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PlayLab Course Highlight -->
    <section class="playlab-course-highlight">
      <div class="max-w-[1200px] mx-auto px-5 py-12 md:px-6 md:py-20">
        <div class="playlab-fade-in text-center max-w-[860px] mx-auto">
          <p class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-4">Play Lab 線上課程</p>
          <h2 class="text-3xl md:text-4xl lg:text-4.5xl font-bold text-brand-primary mb-4 leading-snug md:leading-relaxed">
            「人工智慧運算架構與系統」<br />
            課程上線
          </h2>
          <p class="text-lg md:text-xl text-brand-secondary mb-8">
            學習高效能運算晶片架構<br />
            建立進入 ASIC 產業先備知識
          </p>
          <div class="max-w-[820px] mx-auto text-base md:text-lg text-brand-secondary leading-relaxed space-y-6 mb-10">
            <p>
              隨著晶片複雜度攀升，高效能運算 (HPC) 已成為半導體的核心戰場。臺灣雖擁有堅實的製造基礎，但在前段設計與軟硬體系統整合上仍面臨巨大挑戰。HPC 晶片開發需具備垂直整合視野，為臺灣傳統產學界少見的培育重點。
            </p>
            <p>
              本協會邀請 Play Lab 開設系列課程，打破學界與產業界的藩籬，引進最前瞻的設計方法與概念。我們不僅協助學習者精確掌握核心技能，更打造一個共學研究平台，為學員建立實作即戰力。
            </p>
          </div>
          <a
            href="https://course.playlab.tw/acal"
            class="inline-flex items-center justify-center bg-[linear-gradient(90deg,#6366f1,#4f46e5)] text-white px-7 py-3.5 rounded-full font-semibold shadow-sm transition-transform duration-200 hover:scale-105 hover:shadow-md"
          >
            查看課程介紹
          </a>
        </div>
      </div>
    </section>

    <!-- ACALSim Course (hidden) -->
    <section class="py-16 bg-cream-50 hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-3xl font-bold text-brand-primary mb-6">ACALSim 模擬課程</h2>
              <p class="text-lg text-brand-secondary mb-8">
                專為高效能運算學習設計的互動式模擬課程，結合理論教學與實務操作，
                讓學員在真實的運算環境中學習與實踐。
              </p>
              
              <div class="space-y-4 mb-8">
                <div class="flex items-start">
                  <div class="w-6 h-6 bg-primary-500 rounded-full flex-shrink-0 mt-1 mr-3"></div>
                  <div>
                    <h4 class="font-semibold text-brand-primary">基礎概念</h4>
                    <p class="text-brand-secondary">高效能運算基礎理論與架構介紹</p>
                  </div>
                </div>
                <div class="flex items-start">
                  <div class="w-6 h-6 bg-primary-500 rounded-full flex-shrink-0 mt-1 mr-3"></div>
                  <div>
                    <h4 class="font-semibold text-brand-primary">平行程式設計</h4>
                    <p class="text-brand-secondary">MPI、OpenMP等平行程式設計技術</p>
                  </div>
                </div>
                <div class="flex items-start">
                  <div class="w-6 h-6 bg-primary-500 rounded-full flex-shrink-0 mt-1 mr-3"></div>
                  <div>
                    <h4 class="font-semibold text-brand-primary">GPU運算</h4>
                    <p class="text-brand-secondary">CUDA程式設計與GPU加速技術</p>
                  </div>
                </div>
                <div class="flex items-start">
                  <div class="w-6 h-6 bg-primary-500 rounded-full flex-shrink-0 mt-1 mr-3"></div>
                  <div>
                    <h4 class="font-semibold text-brand-primary">效能最佳化</h4>
                    <p class="text-brand-secondary">程式效能分析與最佳化技術</p>
                  </div>
                </div>
              </div>

              <a href="/education/acalsim-course" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors inline-block">
                立即報名
              </a>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-8">
              <h3 class="text-xl font-semibold text-brand-primary mb-6">課程資訊</h3>
              <div class="space-y-4">
                <div class="flex justify-between">
                  <span class="text-brand-secondary">課程時數</span>
                  <span class="font-semibold text-brand-primary">40小時</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-brand-secondary">上課方式</span>
                  <span class="font-semibold text-brand-primary">線上+實體</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-brand-secondary">課程費用</span>
                  <span class="font-semibold text-brand-primary">NT$ 15,000</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-brand-secondary">認證</span>
                  <span class="font-semibold text-brand-primary">ACAL認證</span>
                </div>
              </div>
              
              <div class="mt-8 pt-6 border-t border-brand-border">
                <h4 class="font-semibold text-brand-primary mb-4">下期開課時間</h4>
                <div class="bg-primary-50 p-4 rounded-lg">
                  <p class="text-primary-800 font-semibold">2024年4月15日 - 5月20日</p>
                  <p class="text-primary-600 text-sm mt-1">每週二、四 19:00-22:00</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Course Categories -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-brand-primary mb-12 text-center">課程分類</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-white rounded-xl shadow-lg p-6">
              <h3 class="text-xl font-semibold text-brand-primary mb-4">基礎課程</h3>
              <ul class="space-y-2 text-brand-secondary mb-6">
                <li>• 運用人工智慧提升行政效率</li>
                <li>• 運算思維與解決問題</li>
                <li>• 程式設計實作</li>
              </ul>
              <span class="text-brand-primary font-medium">適合初學者</span>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6">
              <h3 class="text-xl font-semibold text-brand-primary mb-4">管理課程</h3>
              <ul class="space-y-2 text-brand-secondary mb-6">
                <li>• 開源辦公室建立指南</li>
                <li>• 半導體管理實務</li>
              </ul>
              <span class="text-brand-primary font-medium">適合 HPC 與開源專案管理人士</span>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6">
              <h3 class="text-xl font-semibold text-brand-primary mb-4">專業課程</h3>
              <ul class="space-y-2 text-brand-secondary mb-6">
                <li>• 半導體製程管理</li>
                <li>• 人工智慧設計架構</li>
                <li>• 資訊科技產業專案設計</li>
                <li>• 半導體產業實務</li>
              </ul>
              <span class="text-brand-primary font-medium">深入效能優化與 AI 晶片設計</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Learning Path (hidden) -->
    <section class="py-16 bg-cream-50 hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-brand-primary mb-12 text-center">學習路徑</h2>
          <div class="space-y-8">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-500 text-white rounded-full flex items-center justify-center font-bold">1</div>
              <div class="ml-6">
                <h3 class="text-xl font-semibold text-brand-primary mb-2">基礎建立</h3>
                <p class="text-brand-secondary">學習高效能運算基礎概念與Linux系統操作</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-500 text-white rounded-full flex items-center justify-center font-bold">2</div>
              <div class="ml-6">
                <h3 class="text-xl font-semibold text-brand-primary mb-2">程式開發</h3>
                <p class="text-brand-secondary">掌握平行程式設計技術與開發工具</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-500 text-white rounded-full flex items-center justify-center font-bold">3</div>
              <div class="ml-6">
                <h3 class="text-xl font-semibold text-brand-primary mb-2">效能最佳化</h3>
                <p class="text-brand-secondary">學習程式效能分析與最佳化技術</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-500 text-white rounded-full flex items-center justify-center font-bold">4</div>
              <div class="ml-6">
                <h3 class="text-xl font-semibold text-brand-primary mb-2">專業應用</h3>
                <p class="text-brand-secondary">應用於實際專案與領域特定問題</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-primary-600 text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-6">開始您的學習之旅</h2>
        <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
          加入我們的教育培訓課程，透過實作導向課程縮短學用落差、掌握高效能運算技術，打造未來關鍵競爭力。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/education/acalsim-course" class="hidden bg-white text-primary-600 hover:bg-gray-100 px-8 py-4 rounded-lg text-lg font-semibold transition-colors">
            立即報名
          </a>
          <a href="/join-us" class="border-2 border-white text-white hover:bg-white hover:text-primary-600 px-8 py-4 rounded-lg text-lg font-semibold transition-colors">
            聯絡我們
          </a>
          <a href="/news" class="border-2 border-white text-white hover:bg-white hover:text-primary-600 px-8 py-4 rounded-lg text-lg font-semibold transition-colors">
            即將開課，敬請密切關注
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .playlab-course-highlight {
    background: linear-gradient(135deg, #f7f8fc 0%, #eef1f8 100%);
  }

  .playlab-fade-in {
    animation: playlabFadeIn 0.6s ease-out both;
  }

  @keyframes playlabFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
